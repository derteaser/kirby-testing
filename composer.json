{
  "name": "derteaser/kirby-testing",
  "description": "Fluent HTTP + DOM test assertions for Kirby 5 projects using Pest/PHPUnit.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Jens Kuesters",
      "email": "jens@kuesters.net"
    }
  ],
  "require": {
    "php": "^8.3 || ^8.4 || ^8.5",
    "ext-dom": "*",
    "ext-libxml": "*",
    "getkirby/cms": "^5.0",
    "masterminds/html5": "^2.10",
    "phpunit/phpunit": "^11.0 || ^12.0 || ^13.0",
    "symfony/css-selector": "^7.4 || ^8.0",
    "symfony/dom-crawler": "^7.4 || ^8.0"
  },
  "require-dev": {
    "laravel/pint": "^1.18",
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^2.1"
  },
  "suggest": {
    "loupe/loupe": "Enables the InteractsWithLoupe trait for fixture-backed search indexes (^0.13)."
  },
  "autoload": {
    "psr-4": {
      "Derteaser\\KirbyTesting\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Derteaser\\KirbyTesting\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "getkirby/composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "test": "pest",
    "stan": "phpstan analyse",
    "pint": "pint",
    "pint-test": "pint --test"
  }
}
