{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "concat_space": {
            "spacing": "one"
        },
        "not_operator_with_successor_space": false,
        "single_quote": true,
        "trailing_comma_in_multiline": {
            "elements": ["arrays", "arguments", "parameters", "match"]
        }
    },
    "exclude": [
        "vendor",
        "kirby",
        ".phpunit.cache"
    ]
}
